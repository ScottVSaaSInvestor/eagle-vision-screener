# Eagle Vision Screener — Environment Variables
# Copy this file to .env.local for local development
# NEVER commit real API keys to version control

# ─── SERVER-ONLY (Netlify Functions) ────────────────────────────────────────
# Set these in Netlify dashboard → Site Settings → Environment Variables
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
TAVILY_API_KEY=tvly-...
BRAVE_SEARCH_API_KEY=BSA-...   # Optional fallback
ACCESS_PASSCODE=your-secure-passcode-here

# ─── CLIENT-SAFE (VITE_ prefix — bundled into frontend) ────────────────────
VITE_APP_NAME=Eagle Vision Screener
VITE_APP_VERSION=1.0.0-mvp
