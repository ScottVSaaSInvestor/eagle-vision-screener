# Eagle Vision Screener — Environment Variables
# Copy this file to .env.local for local development
# NEVER commit real API keys to version control

# ─── SERVER-ONLY (Vercel Serverless Functions) ──────────────────────────────
# Set these in Vercel Dashboard → Project → Settings → Environment Variables
ANTHROPIC_API_KEY=sk-ant-...
TAVILY_API_KEY=tvly-...
BRAVE_SEARCH_API_KEY=BSA-...   # Optional fallback search
ACCESS_PASSCODE=your-secure-passcode-here

# ANTHROPIC_MODEL is optional — defaults to claude-opus-4-7 (Feb 2026)
# Vercel has a 300s timeout so Opus works fine without override.
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ─── CLIENT-SAFE (VITE_ prefix — bundled into frontend) ────────────────────
VITE_APP_NAME=Eagle Vision Screener
VITE_APP_VERSION=16.0.0
