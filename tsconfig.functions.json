{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist-functions",
    "baseUrl": ".",
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": ["netlify"]
}
